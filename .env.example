# ==============================================================================
# MARQUE RC INDIA - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' or '.env.local' and populate with your live credentials.
# Under Next.js rules, keys prefixed with 'NEXT_PUBLIC_' are exposed to the client.

# ------------------------------------------------------------------------------
# 1. CORE SUPPORT CONTACT DETAILS (Tamil Nadu Configured)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPPORT_EMAIL=marque0125@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210
NEXT_PUBLIC_Fulfillment_Hub="Chennai Fulfillment Hub, Tamil Nadu"

# ------------------------------------------------------------------------------
# 2. RAZORPAY PAYMENT GATEWAY INTEGRATION (PCI-Compliant Checkouts)
# ------------------------------------------------------------------------------
# Get these keys from your Razorpay Dashboard -> Settings -> API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_yourKeyIdHere
RAZORPAY_KEY_SECRET=yourRazorpayKeySecretHere

# ------------------------------------------------------------------------------
# 3. SHIPROCKET LOGISTICS INTEGRATION (Real-time rates & tracking webhooks)
# ------------------------------------------------------------------------------
# Register at Shiprocket.in and configure credentials for AWB generation callbacks
SHIPROCKET_EMAIL=marque0125@gmail.com
SHIPROCKET_PASSWORD=yourShiprocketPasswordHere

# ------------------------------------------------------------------------------
# 4. DATABASE TELEMETRY & PERSISTENCE (Optional B2B/Prisma configurations)
# ------------------------------------------------------------------------------
# Uncomment and configure if connecting a live PostgreSQL, MySQL, or Neon DB
# DATABASE_URL=postgresql://postgres:secure_password@localhost:5432/marque_db?schema=public
