# ==============================================================================
# MARQUE RC INDIA - PRODUCTION ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to '.env' or '.env.local' and populate with your live credentials.
# Under Next.js rules, keys prefixed with 'NEXT_PUBLIC_' are exposed to the client.

# ------------------------------------------------------------------------------
# 1. SUPABASE — Database & Auth (Required)
# ------------------------------------------------------------------------------
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# ------------------------------------------------------------------------------
# 2. RAZORPAY PAYMENT GATEWAY (PCI-Compliant Checkouts)
# ------------------------------------------------------------------------------
# Get these keys from your Razorpay Dashboard -> Settings -> API Keys
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_yourKeyIdHere
RAZORPAY_KEY_SECRET=yourRazorpayKeySecretHere
# Webhook secret for server-to-server payment verification (Dashboard -> Settings -> Webhooks)
RAZORPAY_WEBHOOK_SECRET=yourRazorpayWebhookSecretHere

# ------------------------------------------------------------------------------
# 3. PHONEPE PAYMENT GATEWAY (UPI / Cards / Netbanking)
# ------------------------------------------------------------------------------
# Get these from the PhonePe Business Dashboard
PHONEPE_CLIENT_ID=your-phonepe-client-id
PHONEPE_CLIENT_SECRET=your-phonepe-client-secret
PHONEPE_CLIENT_VERSION=1
PHONEPE_ENV=PRODUCTION

# ------------------------------------------------------------------------------
# 4. RESEND — Transactional Email (Order Receipts)
# ------------------------------------------------------------------------------
# Sign up at resend.com and create an API key
RESEND_API_KEY=re_yourResendApiKeyHere

# ------------------------------------------------------------------------------
# 5. CLOUDINARY — Image Uploads (Product & Blog Images)
# ------------------------------------------------------------------------------
# Get these from your Cloudinary Dashboard -> Settings
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ------------------------------------------------------------------------------
# 6. CORE SUPPORT CONTACT DETAILS (Tamil Nadu Configured)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPPORT_EMAIL=marque0125@gmail.com
NEXT_PUBLIC_SUPPORT_PHONE=+919876543210
NEXT_PUBLIC_Fulfillment_Hub="Chennai Fulfillment Hub, Tamil Nadu"

# ------------------------------------------------------------------------------
# 7. SHIPROCKET LOGISTICS (Optional — Real-time rates & tracking)
# ------------------------------------------------------------------------------
# Register at Shiprocket.in and configure credentials for AWB generation callbacks
SHIPROCKET_EMAIL=marque0125@gmail.com
SHIPROCKET_PASSWORD=yourShiprocketPasswordHere
